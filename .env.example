# Database
DATABASE_URL=postgresql://user:password@localhost/sayso

# Authentication
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# AI
GROQ_API_KEY=your-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Reminders cron (Authorization: Bearer <value> required on /api/cron/reminders)
CRON_SECRET=your-cron-secret-here

# Application
APP_NAME=Say So
APP_DESCRIPTION=Capture and extract actionable insights from your work input

# Environment
NODE_ENV=development
